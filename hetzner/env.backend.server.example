# Fragmento para backend/.env en el servidor (tras copiar desde .env.example).
# Motor SearXNG: variables propias en searxng/.env.searxng (plantilla searxng/env.searxng.example).

# API pública (Caddy) — si el front llama por HTTPS:
# PUBLIC_APP_URL=https://api.tudominio.com

# SearXNG: app en contenedor en la misma máquina sin red compartida → host gateway Podman:
# SEARXNG_URL=http://host.containers.internal:8088
# Si unes el servicio app a la red investplatform_search (manual / override compose):
# SEARXNG_URL=http://searxng:8080
SEARXNG_URL=http://host.containers.internal:8088

# Postgres/Redis del backend (no uses localhost si app va en contenedor)
# POSTGRES_URL=postgres://body:body@db:5432/body?sslmode=disable
# REDIS_URL=redis://redis:6379/0
