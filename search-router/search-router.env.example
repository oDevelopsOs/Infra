# Public exposure settings
SEARCH_ROUTER_ADDR=:8090
SEARCH_ROUTER_API_KEY=replace_me
SEARCH_ROUTER_RATE_LIMIT_PER_MIN=1200

# Primary provider in the fabric
SEARXNG_URL=http://searxng:8080

# Multi-method fabric (BUSCADORuPDATE): Jina Reader/Search, FlareSolverr, direct HTTP
JINA_ENABLED=true
# Optional — higher rate limits on Jina
# JINA_API_KEY=
FLARESOLVERR_URL=http://flaresolverr:8191
FLARESOLVERR_ENABLED=true

# Crawl4AI (browser crawl → markdown). Compose service: http://crawl4ai:11235
CRAWL4AI_URL=http://crawl4ai:11235
CRAWL4AI_ENABLED=true
# CRAWL4AI_API_TOKEN=

# YaCy P2P search (self-hosted, no Brave key). Compose: http://yacy:8090 — host UI: http://localhost:8091
YACY_URL=http://yacy:8090
YACY_ENABLED=true
# global = ask P2P network; local = this peer index only
YACY_RESOURCE=global
# YACY_USER=
# YACY_PASSWORD=

# Common Crawl — public CDX API (historical URL captures). routing=commoncrawl; query = domain or URL.
COMMONCRAWL_ENABLED=true
COMMONCRAWL_INDEX_ID=CC-MAIN-2025-51
# Full override: https://index.commoncrawl.org/CC-MAIN-2025-51-index/cdx
# COMMONCRAWL_CDX_URL=

# Optional fallbacks (or use routing= tavily / brave on POST /search/query)
TAVILY_API_KEY=
BRAVE_API_KEY=
PERPLEXITY_API_KEY=

# Keep disabled inside router to avoid recursive self-calls.
SEARCH_ROUTER_ENABLED=false

# Redis (same compose service `redis`): enables HTTP response cache for POST /search/query
REDIS_URL=redis://redis:6379/1
# SEARCH_ROUTER_CACHE_ENABLED=   # default: on when REDIS_URL is set; set false to disable
# SEARCH_ROUTER_CACHE_TTL_SECONDS=900

# Latency tuning (search-router process only)
# SEARCH_ROUTER_DEFAULT_TIMEOUT_MS=12000
# SEARCH_MERGE_PARALLEL_TIMEOUT_MS=10000
# SEARCH_MERGE_SKIP_JINA=true
# SEARCH_ROUTER_DEFAULT_LIMIT=6
