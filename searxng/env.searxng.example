# =============================================================================
# SOLO motor de búsqueda (SearXNG + Redis limiter + Nginx edge)
# Copiar a:  .env.searxng   (no subir a git; contiene secretos)
# Arranque:  podman compose -f podman-compose.yml --env-file .env.searxng up -d
#
# La aplicación backend NO usa este archivo: en su .env solo SEARXNG_URL (cómo llegar al motor).
# =============================================================================

# Publicación en host (dev local). En Hetzner detrás de Caddy suele bastar localhost.
SEARXNG_PUBLISH=8088
SEARXNG_EDGE_PUBLISH=8099

# URL pública de la instancia (enlaces en la UI de resultados). Con TLS:
# SEARXNG_BASE_URL=https://search.tudominio.com/
SEARXNG_BASE_URL=http://127.0.0.1:8088/

# Obligatorio en producción: cadena aleatoria larga
SEARXNG_SECRET=change_me_generate_with_openssl_rand_hex_32

# Limiter + Redis de ESTE stack (servicio searxng-redis), no el Redis del backend
SEARXNG_LIMITER=true
SEARXNG_VALKEY_URL=redis://searxng-redis:6379/0
